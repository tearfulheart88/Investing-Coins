# Upbit API Keys
# 업비트 API 키를 발급받아 아래에 입력하세요
# https://upbit.com/mypage/open_api_management
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# Gemini API Key (전략 분석 기능 사용 시 필요)
# https://aistudio.google.com/app/apikey 에서 무료 발급
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub 업로드 기능 활성화 여부 (본인만 true로 설정)
# false 또는 미설정 시 UI의 ↑ GitHub 버튼이 숨겨집니다
GITHUB_UPLOAD_ENABLED=false
